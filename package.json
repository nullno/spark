{
  "name": "@nullno/spark-js",
  "version": "1.0.0",
  "description": "A lightweight declarative JavaScript UI library with 63 built-in components, SPA routing, and zero runtime dependencies",
  "main": "release/spark.min.js",
  "module": "src/index.js",
  "unpkg": "release/spark.min.js",
  "jsdelivr": "release/spark.min.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./release/spark.min.js",
      "default": "./release/spark.min.js"
    }
  },
  "files": [
    "release/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "webpack-dev-server --open --config webpack.dev.js",
    "build": "webpack --config webpack.prod.js",
    "lint": "eslint src/",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nullno/spark.git"
  },
  "keywords": [
    "ui",
    "framework",
    "javascript",
    "declarative",
    "widget",
    "spa",
    "router",
    "lightweight",
    "no-html",
    "component"
  ],
  "author": "wjd",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nullno/spark/issues"
  },
  "homepage": "https://nullno.github.io/spark/",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "babel-core": "^6.26.3",
    "babel-loader": "^7.1.4",
    "babel-plugin-add-module-exports": "^0.2.1",
    "babel-preset-es2015": "^6.24.1",
    "clean-webpack-plugin": "^3.0.0",
    "html-webpack-plugin": "^4.5.0",
    "terser-webpack-plugin": "^4.2.3",
    "webpack": "^4.4.1",
    "webpack-cli": "^3.3.12",
    "webpack-dev-server": "^3.11.0"
  }
}
