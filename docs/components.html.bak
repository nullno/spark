<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Spark.js 组件文档</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--primary:#4B95FF;--primary-dark:#3a7de0;--bg:#fff;--bg-alt:#f8f9fc;--bg-code:#1e293b;--text:#1a1a2e;--text-sec:#64748b;--border:#e2e8f0;--radius:8px;--shadow:0 2px 8px rgba(0,0,0,0.06);--sidebar-w:260px;--header-h:56px}
html{scroll-behavior:smooth}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Noto Sans SC','PingFang SC',sans-serif;color:var(--text);line-height:1.7;background:var(--bg)}
a{color:var(--primary);text-decoration:none}
a:hover{text-decoration:underline}

/* Header */
.header{position:fixed;top:0;left:0;right:0;height:var(--header-h);background:rgba(255,255,255,.95);backdrop-filter:blur(8px);border-bottom:1px solid var(--border);z-index:100;display:flex;align-items:center;padding:0 24px}
.header-logo{font-size:20px;font-weight:800;color:var(--primary);margin-right:24px;letter-spacing:-.5px}
.header-logo span{font-weight:400;font-size:13px;color:var(--text-sec);margin-left:8px}
.header-nav{display:flex;gap:20px;margin-left:auto}
.header-nav a{font-size:14px;color:var(--text-sec);transition:color .2s}
.header-nav a:hover{color:var(--primary);text-decoration:none}
.header-search{margin-left:16px;position:relative}
.header-search input{width:200px;padding:6px 12px 6px 32px;border:1px solid var(--border);border-radius:6px;font-size:13px;outline:none;transition:border-color .2s}
.header-search input:focus{border-color:var(--primary)}
.header-search::before{content:'🔍';position:absolute;left:8px;top:50%;transform:translateY(-50%);font-size:13px}

/* Sidebar */
.sidebar{position:fixed;top:var(--header-h);left:0;width:var(--sidebar-w);height:calc(100vh - var(--header-h));overflow-y:auto;background:var(--bg);border-right:1px solid var(--border);padding:16px 0;z-index:50}
.sidebar::-webkit-scrollbar{width:4px}
.sidebar::-webkit-scrollbar-thumb{background:#ddd;border-radius:2px}
.sidebar-group{margin-bottom:8px}
.sidebar-group-title{font-size:12px;font-weight:600;color:var(--text-sec);text-transform:uppercase;padding:8px 20px 4px;letter-spacing:.5px}
.sidebar-item{display:block;padding:6px 20px 6px 28px;font-size:14px;color:var(--text);border-right:2px solid transparent;transition:all .15s;cursor:pointer}
.sidebar-item:hover{background:var(--bg-alt);color:var(--primary);text-decoration:none}
.sidebar-item.active{color:var(--primary);background:#EBF3FF;border-right-color:var(--primary);font-weight:500}

/* Main Content */
.main{margin-left:var(--sidebar-w);margin-top:var(--header-h);padding:32px 32px 80px}
.main h1{font-size:30px;font-weight:700;margin-bottom:8px;letter-spacing:-.5px}
.main h2{font-size:22px;font-weight:600;margin:32px 0 14px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.main h3{font-size:17px;font-weight:600;margin:24px 0 10px}
.main p{margin-bottom:12px;color:var(--text)}
.main ul,.main ol{margin:0 0 16px 20px}
.main li{margin-bottom:4px}

/* Two-column component layout */
.comp-layout{display:flex;gap:32px;align-items:flex-start}
.comp-doc{flex:1;min-width:0}
.comp-demo{width:340px;flex-shrink:0;position:sticky;top:calc(var(--header-h) + 24px)}
.demo-card{border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;background:#fff}
.demo-card-title{padding:10px 16px;font-size:13px;font-weight:600;color:var(--text-sec);background:var(--bg-alt);border-bottom:1px solid var(--border);letter-spacing:.3px}
.demo-card-body{padding:24px 20px;min-height:120px;display:flex;flex-direction:column;gap:12px;align-items:flex-start}
.demo-card-body.center{align-items:center;justify-content:center}

/* Code */
code{font-family:'Fira Code','JetBrains Mono',Consolas,monospace;font-size:13px;background:#f1f5f9;padding:2px 6px;border-radius:4px;color:#e11d48}
pre{background:var(--bg-code);color:#e2e8f0;padding:20px;border-radius:var(--radius);overflow-x:auto;margin:16px 0;line-height:1.6;position:relative;font-size:13px}
pre code{background:transparent;padding:0;color:inherit}

/* Property list (replaces api-table) */
.prop-list{margin:16px 0;display:flex;flex-direction:column;gap:2px}
.prop-item{display:flex;align-items:baseline;gap:10px;padding:10px 14px;border-radius:6px;background:var(--bg-alt);flex-wrap:wrap}
.prop-item:nth-child(odd){background:#fff;border:1px solid #f0f0f0}
.prop-name{font-family:'Fira Code',Consolas,monospace;font-size:13px;font-weight:600;color:#e11d48;background:#fef2f2;padding:2px 8px;border-radius:4px;white-space:nowrap}
.prop-type{font-size:12px;color:#0958D9;background:#E6F4FF;padding:1px 8px;border-radius:10px;white-space:nowrap}
.prop-default{font-size:12px;color:#64748b;white-space:nowrap}
.prop-default::before{content:'默认: '}
.prop-desc{font-size:13px;color:var(--text-sec);width:100%;margin-top:2px}

/* Tags */
.tag{display:inline-block;padding:1px 8px;border-radius:4px;font-size:12px;font-weight:500;margin-right:4px}
.tag-base{background:#E6F4FF;color:#0958D9}
.tag-extend{background:#F6FFED;color:#389E0D}

/* Section divider */
.section{display:none}
.section.active{display:block}

/* Demo component styles */
.d-btn{display:inline-block;padding:6px 16px;border-radius:6px;font-size:14px;cursor:pointer;border:1px solid var(--primary);color:#fff;background:var(--primary);text-align:center}
.d-btn-outline{background:#fff;color:var(--primary)}
.d-btn-danger{background:#ff4d4f;border-color:#ff4d4f}
.d-btn-sm{padding:3px 10px;font-size:12px}
.d-input{width:100%;padding:7px 12px;border:1px solid var(--border);border-radius:6px;font-size:14px;outline:none;transition:border-color .2s}
.d-input:focus{border-color:var(--primary)}
.d-switch{width:44px;height:22px;border-radius:11px;background:#ccc;position:relative;cursor:pointer;transition:background .2s;display:inline-block}
.d-switch.on{background:var(--primary)}
.d-switch::after{content:'';position:absolute;width:18px;height:18px;border-radius:50%;background:#fff;top:2px;left:2px;transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.2)}
.d-switch.on::after{left:24px}
.d-checkbox{display:flex;align-items:center;gap:8px;cursor:pointer;font-size:14px}
.d-checkbox i{width:16px;height:16px;border:2px solid var(--border);border-radius:3px;display:inline-flex;align-items:center;justify-content:center;font-style:normal;font-size:11px;color:#fff}
.d-checkbox.checked i{background:var(--primary);border-color:var(--primary)}
.d-radio{display:flex;align-items:center;gap:8px;cursor:pointer;font-size:14px}
.d-radio i{width:16px;height:16px;border:2px solid var(--border);border-radius:50%;display:inline-flex;align-items:center;justify-content:center}
.d-radio.checked i{border-color:var(--primary)}
.d-radio.checked i::after{content:'';width:8px;height:8px;border-radius:50%;background:var(--primary)}
.d-tag{display:inline-block;padding:2px 10px;border-radius:4px;font-size:12px;font-weight:500}
.d-tag-blue{background:#E6F4FF;color:#0958D9}
.d-tag-green{background:#F6FFED;color:#389E0D}
.d-tag-red{background:#FFF1F0;color:#CF1322}
.d-tag-orange{background:#FFF7E6;color:#D46B08}
.d-badge{position:relative;display:inline-block}
.d-badge sup{position:absolute;top:-8px;right:-8px;min-width:20px;height:20px;padding:0 6px;border-radius:10px;background:#ff4d4f;color:#fff;font-size:11px;line-height:20px;text-align:center}
.d-badge-dot sup{min-width:8px;height:8px;padding:0;border-radius:50%;top:-4px;right:-4px}
.d-avatar{display:inline-flex;align-items:center;justify-content:center;border-radius:50%;background:var(--primary);color:#fff;font-size:14px;font-weight:500;overflow:hidden}
.d-progress{width:100%;height:8px;border-radius:4px;background:#f0f0f0;overflow:hidden}
.d-progress-bar{height:100%;border-radius:4px;background:var(--primary);transition:width .3s}
.d-alert{width:100%;padding:10px 14px;border-radius:6px;font-size:13px;border:1px solid}
.d-alert-success{background:#F6FFED;border-color:#B7EB8F;color:#389E0D}
.d-alert-info{background:#E6F4FF;border-color:#91CAFF;color:#0958D9}
.d-alert-warning{background:#FFFBE6;border-color:#FFE58F;color:#D48806}
.d-alert-error{background:#FFF2F0;border-color:#FFCCC7;color:#CF1322}
.d-skeleton-line{height:14px;border-radius:4px;background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%);background-size:200% 100%;animation:shimmer 1.5s infinite}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.d-star{font-size:20px;cursor:pointer;color:#e8e8e8}
.d-star.active{color:#fadb14}
.d-card{border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;width:100%}
.d-card-head{padding:10px 16px;border-bottom:1px solid var(--border);font-weight:600;font-size:14px;display:flex;justify-content:space-between;align-items:center}
.d-card-body{padding:16px}
.d-tabs-nav{display:flex;border-bottom:2px solid var(--border)}
.d-tabs-nav span{padding:8px 16px;font-size:14px;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;color:var(--text-sec)}
.d-tabs-nav span.active{color:var(--primary);border-bottom-color:var(--primary);font-weight:500}
.d-step{display:flex;align-items:center;gap:8px;font-size:13px}
.d-step-num{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;border:2px solid var(--border);color:var(--text-sec);flex-shrink:0}
.d-step-num.done{background:var(--primary);border-color:var(--primary);color:#fff}
.d-step-num.current{border-color:var(--primary);color:var(--primary)}
.d-step-line{width:40px;height:2px;background:var(--border)}
.d-step-line.done{background:var(--primary)}
.d-breadcrumb{display:flex;align-items:center;gap:6px;font-size:14px;color:var(--text-sec)}
.d-breadcrumb span:last-child{color:var(--text);font-weight:500}
.d-breadcrumb em{font-style:normal;color:#ccc}
.d-tooltip-wrap{position:relative;display:inline-block}
.d-tooltip{position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);background:rgba(0,0,0,.78);color:#fff;padding:4px 10px;border-radius:4px;font-size:12px;white-space:nowrap}
.d-tooltip::after{content:'';position:absolute;top:100%;left:50%;margin-left:-4px;border:4px solid transparent;border-top-color:rgba(0,0,0,.78)}
.d-collapse-item{border:1px solid var(--border);border-radius:6px;overflow:hidden}
.d-collapse-head{padding:10px 14px;background:var(--bg-alt);font-size:13px;font-weight:500;cursor:pointer;display:flex;justify-content:space-between}
.d-collapse-body{padding:12px 14px;font-size:13px;color:var(--text-sec);border-top:1px solid var(--border)}
.d-slider-track{width:100%;height:6px;background:#f0f0f0;border-radius:3px;position:relative}
.d-slider-fill{height:100%;background:var(--primary);border-radius:3px}
.d-slider-handle{position:absolute;top:50%;width:14px;height:14px;border-radius:50%;background:#fff;border:2px solid var(--primary);transform:translate(-50%,-50%);box-shadow:0 1px 4px rgba(0,0,0,.15)}
.d-empty{text-align:center;padding:24px;color:var(--text-sec)}
.d-empty-icon{font-size:40px;margin-bottom:8px;opacity:.4}
.d-divider{width:100%;border:none;border-top:1px solid var(--border);margin:8px 0}
.d-divider-dashed{border-top-style:dashed}
.d-divider-text{display:flex;align-items:center;gap:12px;font-size:13px;color:var(--text-sec)}
.d-divider-text::before,.d-divider-text::after{content:'';flex:1;height:1px;background:var(--border)}
.d-dropdown-menu{border:1px solid var(--border);border-radius:6px;box-shadow:var(--shadow);overflow:hidden;width:140px}
.d-dropdown-item{padding:6px 14px;font-size:13px;cursor:pointer;transition:background .15s}
.d-dropdown-item:hover{background:var(--bg-alt)}
.d-dropdown-item.danger{color:#ff4d4f}
.d-dropdown-divider{height:1px;background:var(--border);margin:2px 0}
.d-msg{display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:6px;box-shadow:0 4px 12px rgba(0,0,0,.12);font-size:14px;background:#fff}
.d-drawer{border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;width:100%}
.d-drawer-head{padding:12px 16px;border-bottom:1px solid var(--border);font-weight:600;font-size:14px;display:flex;justify-content:space-between}
.d-drawer-body{padding:16px;min-height:60px;background:var(--bg-alt);font-size:13px;color:var(--text-sec)}

/* Component grid for overview */
.comp-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px;margin:16px 0}
.comp-grid-item{padding:10px 14px;border:1px solid var(--border);border-radius:6px;font-size:13px;cursor:pointer;transition:all .15s}
.comp-grid-item:hover{border-color:var(--primary);background:#EBF3FF}
.comp-grid-item code{font-size:12px;display:block;margin-bottom:2px}
.comp-grid-item span{font-size:12px;color:var(--text-sec)}

/* Responsive */
@media(max-width:1100px){
  .comp-demo{display:none}
}
@media(max-width:768px){
  .sidebar{display:none}
  .main{margin-left:0;padding:24px 16px 60px}
}
</style>
</head>
<body>

<!-- Header -->
<header class="header">
  <a class="header-logo" href="#overview">Spark.js<span>v1.0.0</span></a>
  <nav class="header-nav">
    <a href="index.html">首页</a>
    <a href="https://github.com" target="_blank">GitHub</a>
  </nav>
  <div class="header-search"><input type="text" placeholder="搜索组件..."></div>
</header>

<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-group">
    <div class="sidebar-group-title">开始</div>
    <a class="sidebar-item active" data-section="overview" onclick="showSection('overview')">概览</a>
    <a class="sidebar-item" data-section="quickstart" onclick="showSection('quickstart')">快速上手</a>
    <a class="sidebar-item" data-section="api" onclick="showSection('api')">核心 API</a>
  </div>
  <div class="sidebar-group">
    <div class="sidebar-group-title">通用</div>
    <a class="sidebar-item" data-section="comp-text" onclick="showSection('comp-text')">Text 文本</a>
    <a class="sidebar-item" data-section="comp-button" onclick="showSection('comp-button')">Button 按钮</a>
    <a class="sidebar-item" data-section="comp-link" onclick="showSection('comp-link')">Link 链接</a>
    <a class="sidebar-item" data-section="comp-image" onclick="showSection('comp-image')">Image 图片</a>
    <a class="sidebar-item" data-section="comp-divider" onclick="showSection('comp-divider')">Divider 分割线</a>
  </div>
  <div class="sidebar-group">
    <div class="sidebar-group-title">布局</div>
    <a class="sidebar-item" data-section="comp-box" onclick="showSection('comp-box')">Box 容器</a>
    <a class="sidebar-item" data-section="comp-row" onclick="showSection('comp-row')">Row / Col 栅格</a>
    <a class="sidebar-item" data-section="comp-space" onclick="showSection('comp-space')">Space 间距</a>
    <a class="sidebar-item" data-section="comp-stack" onclick="showSection('comp-stack')">Stack 层叠</a>
    <a class="sidebar-item" data-section="comp-position" onclick="showSection('comp-position')">Position 定位</a>
    <a class="sidebar-item" data-section="comp-fixed" onclick="showSection('comp-fixed')">Fixed 固定</a>
  </div>
  <div class="sidebar-group">
    <div class="sidebar-group-title">数据录入</div>
    <a class="sidebar-item" data-section="comp-input" onclick="showSection('comp-input')">Input 输入框</a>
    <a class="sidebar-item" data-section="comp-checkbox" onclick="showSection('comp-checkbox')">Checkbox 复选</a>
    <a class="sidebar-item" data-section="comp-radio" onclick="showSection('comp-radio')">Radio 单选</a>
    <a class="sidebar-item" data-section="comp-switch" onclick="showSection('comp-switch')">Switch 开关</a>
    <a class="sidebar-item" data-section="comp-rate" onclick="showSection('comp-rate')">Rate 评分</a>
    <a class="sidebar-item" data-section="comp-slider" onclick="showSection('comp-slider')">Slider 滑条</a>
  </div>
  <div class="sidebar-group">
    <div class="sidebar-group-title">数据展示</div>
    <a class="sidebar-item" data-section="comp-badge" onclick="showSection('comp-badge')">Badge 徽标</a>
    <a class="sidebar-item" data-section="comp-tag" onclick="showSection('comp-tag')">Tag 标签</a>
    <a class="sidebar-item" data-section="comp-card" onclick="showSection('comp-card')">Card 卡片</a>
    <a class="sidebar-item" data-section="comp-tabs" onclick="showSection('comp-tabs')">Tabs 标签页</a>
    <a class="sidebar-item" data-section="comp-avatar" onclick="showSection('comp-avatar')">Avatar 头像</a>
    <a class="sidebar-item" data-section="comp-collapse" onclick="showSection('comp-collapse')">Collapse 折叠面板</a>
    <a class="sidebar-item" data-section="comp-steps" onclick="showSection('comp-steps')">Steps 步骤条</a>
    <a class="sidebar-item" data-section="comp-progress" onclick="showSection('comp-progress')">Progress 进度条</a>
    <a class="sidebar-item" data-section="comp-empty" onclick="showSection('comp-empty')">Empty 空状态</a>
    <a class="sidebar-item" data-section="comp-skeleton" onclick="showSection('comp-skeleton')">Skeleton 骨架屏</a>
    <a class="sidebar-item" data-section="comp-list" onclick="showSection('comp-list')">List 列表</a>
    <a class="sidebar-item" data-section="comp-breadcrumb" onclick="showSection('comp-breadcrumb')">Breadcrumb 面包屑</a>
    <a class="sidebar-item" data-section="comp-tooltip" onclick="showSection('comp-tooltip')">Tooltip 提示</a>
  </div>
  <div class="sidebar-group">
    <div class="sidebar-group-title">反馈</div>
    <a class="sidebar-item" data-section="comp-alert" onclick="showSection('comp-alert')">Alert 警告</a>
    <a class="sidebar-item" data-section="comp-modal" onclick="showSection('comp-modal')">Modal 对话框</a>
    <a class="sidebar-item" data-section="comp-drawer" onclick="showSection('comp-drawer')">Drawer 抽屉</a>
    <a class="sidebar-item" data-section="comp-message" onclick="showSection('comp-message')">Message 消息</a>
    <a class="sidebar-item" data-section="comp-notification" onclick="showSection('comp-notification')">Notification 通知</a>
    <a class="sidebar-item" data-section="comp-dropdown" onclick="showSection('comp-dropdown')">Dropdown 下拉菜单</a>
  </div>
  <div class="sidebar-group">
    <div class="sidebar-group-title">其他</div>
    <a class="sidebar-item" data-section="comp-backtop" onclick="showSection('comp-backtop')">BackTop 回到顶部</a>
    <a class="sidebar-item" data-section="comp-drag" onclick="showSection('comp-drag')">Drag 拖拽</a>
  </div>
</aside>

<!-- Content -->
<main class="main" id="content">

<!-- =================== 概览 =================== -->
<div class="section active" id="overview">
<h1>Spark.js 组件文档</h1>
<p>Spark.js 是一个轻量级声明式 JavaScript UI 库，用纯 JS 构建 Web 界面，无需 HTML 模板、无需打包工具。<br>灵感来源于 Flutter/Dart 的声明式组件风格。</p>

<h2>基础组件 <span class="tag tag-base">Base</span></h2>
<div class="comp-grid">
  <div class="comp-grid-item" onclick="showSection('comp-text')"><code>Spark.Text()</code><span>文本组件</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-box')"><code>Spark.Box()</code><span>通用容器</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-image')"><code>Spark.Image()</code><span>图片组件</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-button')"><code>Spark.Button()</code><span>按钮组件</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-link')"><code>Spark.Link()</code><span>超链接组件</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-input')"><code>Spark.Input()</code><span>输入框</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-switch')"><code>Spark.Switch()</code><span>开关切换</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-checkbox')"><code>Spark.Checkbox()</code><span>复选框</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-radio')"><code>Spark.Radio()</code><span>单选按钮</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-divider')"><code>Spark.Divider()</code><span>分割线</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-row')"><code>Spark.Row/Col</code><span>Flex 栅格</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-space')"><code>Spark.Space()</code><span>间距容器</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-list')"><code>Spark.List()</code><span>列表渲染</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-drag')"><code>Spark.Drag()</code><span>拖拽容器</span></div>
</div>

<h2>扩展组件 <span class="tag tag-extend">Extend</span></h2>
<div class="comp-grid">
  <div class="comp-grid-item" onclick="showSection('comp-alert')"><code>Spark.Alert()</code><span>警告提示框</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-avatar')"><code>Spark.Avatar()</code><span>用户头像</span></div>
  <div class="comp-grid-item" onclick="showSection('comp-backtop')"><code>Spark.BackTop()</code><span>回到顶部</span></div>
