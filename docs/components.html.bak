<!-- =================== Divider 分割线 =================== -->
<div class="section" id="comp-divider">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Divider 分割线 <span class="tag tag-base">Base</span></h1>
    <p>用于内容区域的分割或标题分组。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Divider();
Spark.Divider("章节标题");
Spark.Divider("", { dashed: true });
Spark.Divider("", { type: "vertical" });</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">第 1 参数</span><span class="prop-type">String</span><span class="prop-default">""</span><span class="prop-desc">分割线文字（居中显示）</span></div>
      <div class="prop-item"><span class="prop-name">type</span><span class="prop-type">String</span><span class="prop-default">"horizontal"</span><span class="prop-desc">方向：horizontal / vertical</span></div>
      <div class="prop-item"><span class="prop-name">dashed</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">是否虚线样式</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%">
        <span style="font-size:13px;color:var(--text-sec)">上方内容</span>
        <hr class="d-divider">
        <div class="d-divider-text">章节标题</div>
        <hr class="d-divider d-divider-dashed">
        <span style="font-size:13px;color:var(--text-sec)">下方内容</span>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Box 容器 =================== -->
<div class="section" id="comp-box">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Box 容器 <span class="tag tag-base">Base</span></h1>
    <p>通用容器组件，渲染为 <code>&lt;div&gt;</code>，可包含任意子组件。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Box({
  style: "padding: 16px; background: #f5f5f5; border-radius: 8px;",
  child: [
    Spark.Text("容器内的内容"),
    Spark.Button("操作按钮")
  ]
});</code></pre>
    <h2>Flex 布局</h2>
    <pre><code>Spark.Box({
  style: "display: flex; gap: 16px; align-items: center;",
  child: [
    Spark.Box({ style: "width:80px; height:80px; background:#4B95FF;" }),
    Spark.Box({ style: "width:80px; height:80px; background:#52c41a;" }),
    Spark.Box({ style: "width:80px; height:80px; background:#faad14;" })
  ]
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">style</span><span class="prop-type">String</span><span class="prop-desc">CSS 内联样式</span></div>
      <div class="prop-item"><span class="prop-name">child</span><span class="prop-type">Array</span><span class="prop-desc">子组件数组</span></div>
      <div class="prop-item"><span class="prop-name">onClick</span><span class="prop-type">Function</span><span class="prop-desc">点击事件</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body center">
        <div style="padding:16px;background:#f5f5f5;border-radius:8px;width:100%">
          <div style="font-size:14px;margin-bottom:8px;">容器内的内容</div>
          <span class="d-btn d-btn-sm">操作按钮</span>
        </div>
        <div style="display:flex;gap:12px;margin-top:4px">
          <div style="width:50px;height:50px;background:#4B95FF;border-radius:6px;"></div>
          <div style="width:50px;height:50px;background:#52c41a;border-radius:6px;"></div>
          <div style="width:50px;height:50px;background:#faad14;border-radius:6px;"></div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Row / Col 栅格 =================== -->
<div class="section" id="comp-row">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Row / Col 栅格 <span class="tag tag-base">Base</span></h1>
    <p>基于 Flex 的栅格布局系统。Row 为行容器，Col 为列。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Row({
  gutter: 16,
  child: [
    Spark.Col({ span: 12, child: [...] }),
    Spark.Col({ span: 12, child: [...] })
  ]
});</code></pre>
    <h2>API - Row</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">gutter</span><span class="prop-type">Number</span><span class="prop-default">0</span><span class="prop-desc">列间距 (px)</span></div>
      <div class="prop-item"><span class="prop-name">justify</span><span class="prop-type">String</span><span class="prop-default">"flex-start"</span><span class="prop-desc">水平排列方式</span></div>
      <div class="prop-item"><span class="prop-name">align</span><span class="prop-type">String</span><span class="prop-default">"top"</span><span class="prop-desc">垂直对齐方式</span></div>
      <div class="prop-item"><span class="prop-name">wrap</span><span class="prop-type">Boolean</span><span class="prop-default">true</span><span class="prop-desc">是否换行</span></div>
    </div>
    <h2>API - Col</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">span</span><span class="prop-type">Number</span><span class="prop-default">24</span><span class="prop-desc">占据列数（0-24）</span></div>
      <div class="prop-item"><span class="prop-name">offset</span><span class="prop-type">Number</span><span class="prop-default">0</span><span class="prop-desc">左偏移列数</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%">
        <div style="display:flex;gap:8px;width:100%">
          <div style="flex:1;height:36px;background:#4B95FF;border-radius:4px;opacity:.9"></div>
          <div style="flex:1;height:36px;background:#69b1ff;border-radius:4px;"></div>
        </div>
        <div style="display:flex;gap:8px;width:100%">
          <div style="flex:1;height:36px;background:#4B95FF;border-radius:4px;opacity:.9"></div>
          <div style="flex:2;height:36px;background:#69b1ff;border-radius:4px;"></div>
        </div>
        <div style="display:flex;gap:8px;width:100%">
          <div style="flex:1;height:36px;background:#4B95FF;border-radius:4px;opacity:.9"></div>
          <div style="flex:1;height:36px;background:#69b1ff;border-radius:4px;"></div>
          <div style="flex:1;height:36px;background:#4B95FF;border-radius:4px;opacity:.9"></div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Space 间距 =================== -->
<div class="section" id="comp-space">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Space 间距 <span class="tag tag-base">Base</span></h1>
    <p>在子组件之间设置统一间距。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Space({
  size: 12,
  direction: "horizontal",
  child: [
    Spark.Button("按钮1"),
    Spark.Button("按钮2"),
    Spark.Button("按钮3")
  ]
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">size</span><span class="prop-type">Number</span><span class="prop-default">8</span><span class="prop-desc">间距大小 (px)</span></div>
      <div class="prop-item"><span class="prop-name">direction</span><span class="prop-type">String</span><span class="prop-default">"horizontal"</span><span class="prop-desc">horizontal / vertical</span></div>
      <div class="prop-item"><span class="prop-name">wrap</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">是否允许换行</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body">
        <div style="display:flex;gap:12px">
          <span class="d-btn d-btn-sm">按钮1</span>
          <span class="d-btn d-btn-sm">按钮2</span>
          <span class="d-btn d-btn-sm">按钮3</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;margin-top:4px">
          <span class="d-btn d-btn-sm d-btn-outline">垂直1</span>
          <span class="d-btn d-btn-sm d-btn-outline">垂直2</span>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Stack 层叠 =================== -->
<div class="section" id="comp-stack">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Stack 层叠 <span class="tag tag-base">Base</span></h1>
    <p>相对定位容器，子元素可使用绝对定位。类似 Flutter 的 Stack。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Stack({
  style: "width: 200px; height: 200px;",
  child: [
    Spark.Box({ style: "width:100%; height:100%; background:#4B95FF;" }),
    Spark.Position({
      style: "bottom:8px; right:8px;",
      child: [Spark.Text("右下角", { style: "color:#fff;" })]
    })
  ]
});</code></pre>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body center">
        <div style="position:relative;width:160px;height:120px;background:#4B95FF;border-radius:8px;">
          <span style="position:absolute;bottom:8px;right:8px;color:#fff;font-size:13px;">右下角</span>
          <span style="position:absolute;top:8px;left:8px;color:rgba(255,255,255,.7);font-size:11px;">Stack</span>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Position 定位 =================== -->
<div class="section" id="comp-position">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Position 定位 <span class="tag tag-base">Base</span></h1>
    <p>绝对定位容器，常搭配 Stack 使用。</p>
    <pre><code>Spark.Position({
  style: "top: 10px; left: 10px;",
  child: [Spark.Text("绝对定位内容")]
});</code></pre>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body center">
        <div style="position:relative;width:160px;height:100px;background:var(--bg-alt);border:1px dashed var(--border);border-radius:6px;">
          <span style="position:absolute;top:10px;left:10px;font-size:13px;color:var(--primary);">绝对定位内容</span>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Fixed 固定 =================== -->
<div class="section" id="comp-fixed">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Fixed 固定 <span class="tag tag-base">Base</span></h1>
    <p>固定定位容器，常用于导航栏、悬浮按钮等。</p>
    <pre><code>Spark.Fixed({
  style: "bottom: 20px; right: 20px;",
  child: [Spark.Button("悬浮按钮")]
});</code></pre>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body center">
        <div style="position:relative;width:160px;height:100px;background:var(--bg-alt);border:1px dashed var(--border);border-radius:6px;overflow:hidden">
          <div style="position:absolute;bottom:8px;right:8px;"><span class="d-btn d-btn-sm">悬浮</span></div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Input 输入框 =================== -->
<div class="section" id="comp-input">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Input 输入框 <span class="tag tag-base">Base</span></h1>
    <p>输入框组件，支持 input/paste/blur/focus/keydown 等事件，支持响应式 value。</p>
    <h2>基础用法</h2>
    <pre><code>var input = Spark.Input({
  placeholder: "请输入内容...",
  style: "width: 300px;",
  input: function (e) {
    console.log("输入值:", e.target.value);
  }
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">type</span><span class="prop-type">String</span><span class="prop-desc">input 类型 (text/password/number)</span></div>
      <div class="prop-item"><span class="prop-name">placeholder</span><span class="prop-type">String</span><span class="prop-desc">占位文字</span></div>
      <div class="prop-item"><span class="prop-name">value</span><span class="prop-type">String</span><span class="prop-desc">初始值</span></div>
      <div class="prop-item"><span class="prop-name">disabled</span><span class="prop-type">Boolean</span><span class="prop-desc">是否禁用</span></div>
      <div class="prop-item"><span class="prop-name">input</span><span class="prop-type">Function</span><span class="prop-desc">输入事件回调</span></div>
      <div class="prop-item"><span class="prop-name">paste</span><span class="prop-type">Function</span><span class="prop-desc">粘贴事件回调</span></div>
      <div class="prop-item"><span class="prop-name">onblur</span><span class="prop-type">Function</span><span class="prop-desc">失焦回调</span></div>
      <div class="prop-item"><span class="prop-name">onfocus</span><span class="prop-type">Function</span><span class="prop-desc">聚焦回调</span></div>
      <div class="prop-item"><span class="prop-name">onkeydown</span><span class="prop-type">Function</span><span class="prop-desc">按键回调</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%">
        <input class="d-input" type="text" placeholder="请输入内容...">
        <input class="d-input" type="text" placeholder="密码输入框" style="margin-top:4px">
        <input class="d-input" type="text" placeholder="禁用状态" disabled style="margin-top:4px;opacity:.5;cursor:not-allowed">
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Checkbox 复选 =================== -->
<div class="section" id="comp-checkbox">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Checkbox 复选框 <span class="tag tag-base">Base</span></h1>
    <p>复选框组件，带文本标签。</p>
    <h2>基础用法</h2>
    <pre><code>var cb = Spark.Checkbox("记住密码", {
  checked: false,
  onChange: function (checked) {
    console.log("选中:", checked);
  }
});
cb.getValue();
cb.setValue(true);</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">第 1 参数</span><span class="prop-type">String</span><span class="prop-default">""</span><span class="prop-desc">标签文字</span></div>
      <div class="prop-item"><span class="prop-name">checked</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">初始选中状态</span></div>
      <div class="prop-item"><span class="prop-name">disabled</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">是否禁用</span></div>
      <div class="prop-item"><span class="prop-name">onChange</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">状态变化回调 (checked)</span></div>
    </div>
    <h3>方法</h3>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">getValue()</span><span class="prop-desc">获取当前选中值</span></div>
      <div class="prop-item"><span class="prop-name">setValue(bool)</span><span class="prop-desc">程序设置选中状态</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body">
        <label class="d-checkbox checked"><i>✓</i> 记住密码</label>
        <label class="d-checkbox"><i></i> 自动登录</label>
        <label class="d-checkbox checked"><i>✓</i> 同意协议</label>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Radio 单选 =================== -->
<div class="section" id="comp-radio">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Radio 单选按钮 <span class="tag tag-base">Base</span></h1>
    <p>单选按钮及单选组。</p>
    <h2>基础用法</h2>
    <pre><code>var group = Spark.RadioGroup({
  value: "apple",
  options: [
    { label: "苹果", value: "apple" },
    { label: "橘子", value: "orange" },
    { label: "香蕉", value: "banana" }
  ],
  onChange: function (val) {
    console.log("选中:", val);
  }
});</code></pre>
    <h2>API - RadioGroup</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">value</span><span class="prop-type">String</span><span class="prop-desc">当前选中值</span></div>
      <div class="prop-item"><span class="prop-name">options</span><span class="prop-type">Array</span><span class="prop-desc">[{ label, value }] 选项列表</span></div>
      <div class="prop-item"><span class="prop-name">onChange</span><span class="prop-type">Function</span><span class="prop-desc">选中变化回调 (value)</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body">
        <label class="d-radio checked"><i></i> 苹果</label>
        <label class="d-radio"><i></i> 橘子</label>
        <label class="d-radio"><i></i> 香蕉</label>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Switch 开关 =================== -->
<div class="section" id="comp-switch">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Switch 开关 <span class="tag tag-base">Base</span></h1>
    <p>开关切换组件，支持自定义大小和颜色。</p>
    <h2>基础用法</h2>
    <pre><code>var sw = Spark.Switch({
  checked: true,
  onChange: function (val) {
    console.log("开关状态:", val);
  }
});
sw.getValue();
sw.setValue(false);</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">checked</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">初始开关状态</span></div>
      <div class="prop-item"><span class="prop-name">disabled</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">是否禁用</span></div>
      <div class="prop-item"><span class="prop-name">activeColor</span><span class="prop-type">String</span><span class="prop-default">"#4B95FF"</span><span class="prop-desc">激活时颜色</span></div>
      <div class="prop-item"><span class="prop-name">size</span><span class="prop-type">String</span><span class="prop-default">"default"</span><span class="prop-desc">尺寸: default / small</span></div>
      <div class="prop-item"><span class="prop-name">onChange</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">状态变化回调 (checked)</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body">
        <div style="display:flex;align-items:center;gap:12px">
          <span class="d-switch on"></span>
          <span style="font-size:13px">开启</span>
        </div>
        <div style="display:flex;align-items:center;gap:12px">
          <span class="d-switch"></span>
          <span style="font-size:13px">关闭</span>
        </div>
        <div style="display:flex;align-items:center;gap:12px">
          <span class="d-switch" style="opacity:.5;cursor:not-allowed"></span>
          <span style="font-size:13px;color:var(--text-sec)">禁用</span>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Rate 评分 =================== -->
<div class="section" id="comp-rate">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Rate 评分 <span class="tag tag-extend">Extend</span></h1>
    <p>星级评分组件。</p>
    <h2>基础用法</h2>
    <pre><code>var rate = Spark.Rate({
  value: 3, count: 5,
  onChange: function (val) { console.log("评分:", val); }
});
rate.getValue();
rate.setValue(5);</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">value</span><span class="prop-type">Number</span><span class="prop-default">0</span><span class="prop-desc">当前评分</span></div>
      <div class="prop-item"><span class="prop-name">count</span><span class="prop-type">Number</span><span class="prop-default">5</span><span class="prop-desc">星星总数</span></div>
      <div class="prop-item"><span class="prop-name">disabled</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">是否禁用</span></div>
      <div class="prop-item"><span class="prop-name">color</span><span class="prop-type">String</span><span class="prop-default">"#fadb14"</span><span class="prop-desc">激活颜色</span></div>
      <div class="prop-item"><span class="prop-name">size</span><span class="prop-type">Number</span><span class="prop-default">20</span><span class="prop-desc">星星大小 (px)</span></div>
      <div class="prop-item"><span class="prop-name">character</span><span class="prop-type">String</span><span class="prop-default">"★"</span><span class="prop-desc">评分字符</span></div>
      <div class="prop-item"><span class="prop-name">onChange</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">评分改变回调 (value)</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body">
        <div><span class="d-star active">★</span><span class="d-star active">★</span><span class="d-star active">★</span><span class="d-star">★</span><span class="d-star">★</span> <span style="font-size:13px;color:var(--text-sec);margin-left:8px">3 分</span></div>
        <div><span class="d-star active">★</span><span class="d-star active">★</span><span class="d-star active">★</span><span class="d-star active">★</span><span class="d-star active">★</span> <span style="font-size:13px;color:var(--text-sec);margin-left:8px">5 分</span></div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Slider 滑条 =================== -->
<div class="section" id="comp-slider">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Slider 滑动输入条 <span class="tag tag-extend">Extend</span></h1>
    <p>滑动范围选择器。</p>
    <h2>基础用法</h2>
    <pre><code>var slider = Spark.Slider({
  min: 0, max: 100, value: 30,
  onChange: function (val) { console.log("值:", val); }
});
slider.setValue(50);</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">min</span><span class="prop-type">Number</span><span class="prop-default">0</span><span class="prop-desc">最小值</span></div>
      <div class="prop-item"><span class="prop-name">max</span><span class="prop-type">Number</span><span class="prop-default">100</span><span class="prop-desc">最大值</span></div>
      <div class="prop-item"><span class="prop-name">value</span><span class="prop-type">Number</span><span class="prop-default">0</span><span class="prop-desc">当前值</span></div>
      <div class="prop-item"><span class="prop-name">step</span><span class="prop-type">Number</span><span class="prop-default">1</span><span class="prop-desc">步长</span></div>
      <div class="prop-item"><span class="prop-name">disabled</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">是否禁用</span></div>
      <div class="prop-item"><span class="prop-name">showTooltip</span><span class="prop-type">Boolean</span><span class="prop-default">true</span><span class="prop-desc">是否显示提示</span></div>
      <div class="prop-item"><span class="prop-name">onChange</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">值变化回调 (value)</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%">
        <div style="width:100%">
          <div class="d-slider-track">
            <div class="d-slider-fill" style="width:30%"></div>
            <div class="d-slider-handle" style="left:30%"></div>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text-sec);margin-top:4px"><span>0</span><span>30</span><span>100</span></div>
        </div>
        <div style="width:100%;margin-top:8px">
          <div class="d-slider-track">
            <div class="d-slider-fill" style="width:70%"></div>
            <div class="d-slider-handle" style="left:70%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Badge 徽标 =================== -->
<div class="section" id="comp-badge">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Badge 徽标数 <span class="tag tag-extend">Extend</span></h1>
    <p>在元素右上角展示状态数字或小红点。</p>
    <h2>基础用法</h2>
    <pre><code>var badge = Spark.Badge({
  count: 5,
  child: Spark.Box({
    style: "width:42px; height:42px; background:#f0f0f0; border-radius:4px;"
  })
});

Spark.Badge({ dot: true, child: Spark.Text("通知") });
badge.setCount(99);</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">count</span><span class="prop-type">Number</span><span class="prop-default">0</span><span class="prop-desc">展示数量</span></div>
      <div class="prop-item"><span class="prop-name">dot</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">仅展示小红点</span></div>
      <div class="prop-item"><span class="prop-name">maxCount</span><span class="prop-type">Number</span><span class="prop-default">99</span><span class="prop-desc">最大展示数字，超过显示 maxCount+</span></div>
      <div class="prop-item"><span class="prop-name">showZero</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">count=0 时是否展示</span></div>
      <div class="prop-item"><span class="prop-name">color</span><span class="prop-type">String</span><span class="prop-default">"#ff4d4f"</span><span class="prop-desc">徽标颜色</span></div>
      <div class="prop-item"><span class="prop-name">child</span><span class="prop-type">Widget</span><span class="prop-default">-</span><span class="prop-desc">被装饰的子组件</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body">
        <div style="display:flex;gap:24px;align-items:flex-start">
          <span class="d-badge"><div style="width:42px;height:42px;background:#f0f0f0;border-radius:4px;"></div><sup>5</sup></span>
          <span class="d-badge"><div style="width:42px;height:42px;background:#f0f0f0;border-radius:4px;"></div><sup>99+</sup></span>
          <span class="d-badge d-badge-dot"><div style="width:42px;height:42px;background:#f0f0f0;border-radius:4px;"></div><sup></sup></span>
        </div>
        <div style="display:flex;gap:24px;align-items:center;margin-top:8px">
          <span class="d-badge" style="display:inline"><span style="font-size:14px">通知</span><sup style="position:relative;top:-2px;right:auto;margin-left:4px;display:inline-block">12</sup></span>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Tag 标签 =================== -->
<div class="section" id="comp-tag">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Tag 标签 <span class="tag tag-extend">Extend</span></h1>
    <p>分类标签，支持预设颜色和可关闭。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Tag({ text: "蓝色", color: "blue" });
Spark.Tag({ text: "绿色", color: "green" });
Spark.Tag({ text: "红色", color: "red" });
Spark.Tag({
  text: "关闭我", closable: true,
  onClose: function () { console.log("关闭"); }
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">text</span><span class="prop-type">String</span><span class="prop-default">""</span><span class="prop-desc">标签文字</span></div>
      <div class="prop-item"><span class="prop-name">color</span><span class="prop-type">String</span><span class="prop-default">"blue"</span><span class="prop-desc">预设颜色: blue/green/red/orange/gold/cyan/purple/magenta</span></div>
      <div class="prop-item"><span class="prop-name">customColor</span><span class="prop-type">String</span><span class="prop-default">-</span><span class="prop-desc">自定义背景色</span></div>
      <div class="prop-item"><span class="prop-name">closable</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">是否可关闭</span></div>
      <div class="prop-item"><span class="prop-name">onClose</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">关闭回调</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body">
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <span class="d-tag d-tag-blue">蓝色</span>
          <span class="d-tag d-tag-green">绿色</span>
          <span class="d-tag d-tag-red">红色</span>
          <span class="d-tag d-tag-orange">橙色</span>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <span class="d-tag d-tag-blue">可关闭 ×</span>
          <span class="d-tag" style="background:#f9f0ff;color:#722ed1">自定义</span>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Card 卡片 =================== -->
<div class="section" id="comp-card">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Card 卡片 <span class="tag tag-extend">Extend</span></h1>
    <p>通用卡片容器，支持标题、额外操作、封面、底部操作栏。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Card({
  title: "卡片标题",
  extra: Spark.Link("更多", { href: "#" }),
  hoverable: true,
  child: [Spark.Text("这是卡片内容区域")]
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">title</span><span class="prop-type">String</span><span class="prop-default">""</span><span class="prop-desc">卡片标题</span></div>
      <div class="prop-item"><span class="prop-name">extra</span><span class="prop-type">Widget</span><span class="prop-default">-</span><span class="prop-desc">标题右侧额外内容</span></div>
      <div class="prop-item"><span class="prop-name">cover</span><span class="prop-type">String</span><span class="prop-default">-</span><span class="prop-desc">封面图片 URL</span></div>
      <div class="prop-item"><span class="prop-name">bordered</span><span class="prop-type">Boolean</span><span class="prop-default">true</span><span class="prop-desc">是否有边框</span></div>
      <div class="prop-item"><span class="prop-name">hoverable</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">鼠标悬停时抬起阴影</span></div>
      <div class="prop-item"><span class="prop-name">actions</span><span class="prop-type">Array</span><span class="prop-default">-</span><span class="prop-desc">底部操作栏 (Widget 数组)</span></div>
      <div class="prop-item"><span class="prop-name">child</span><span class="prop-type">Array</span><span class="prop-default">-</span><span class="prop-desc">卡片 body 内容</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%">
        <div class="d-card">
          <div class="d-card-head"><span>卡片标题</span><a href="javascript:;" style="font-size:13px;color:var(--primary)">更多</a></div>
          <div class="d-card-body" style="font-size:14px;color:var(--text);">这是卡片内容区域<br><span style="color:var(--text-sec);font-size:13px">支持标题、封面、操作栏</span></div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Tabs 标签页 =================== -->
<div class="section" id="comp-tabs">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Tabs 标签页 <span class="tag tag-extend">Extend</span></h1>
    <p>选项卡切换组件。</p>
    <h2>基础用法</h2>
    <pre><code>var tabs = Spark.Tabs({
  activeKey: "tab1",
  items: [
    { key: "tab1", label: "选项卡1", children: [Spark.Text("内容1")] },
    { key: "tab2", label: "选项卡2", children: [Spark.Text("内容2")] }
  ],
  onChange: function (key) { console.log("切换到:", key); }
});
tabs.setActiveKey("tab2");</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">activeKey</span><span class="prop-type">String</span><span class="prop-default">第一项 key</span><span class="prop-desc">当前激活 key</span></div>
      <div class="prop-item"><span class="prop-name">items</span><span class="prop-type">Array</span><span class="prop-default">[]</span><span class="prop-desc">[{ key, label, children }]</span></div>
      <div class="prop-item"><span class="prop-name">onChange</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">切换回调 (key)</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%;padding:0">
        <div class="d-tabs-nav" style="width:100%">
          <span class="active">选项卡1</span>
          <span>选项卡2</span>
          <span>选项卡3</span>
        </div>
        <div style="padding:16px 20px;font-size:14px;color:var(--text)">选项卡1的内容</div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Avatar 头像 =================== -->
<div class="section" id="comp-avatar">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Avatar 头像 <span class="tag tag-extend">Extend</span></h1>
    <p>用户头像组件，支持图片、文字、不同形状和大小。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Avatar({ src: "https://example.com/avatar.jpg" });
Spark.Avatar({ text: "李", color: "#f56a00" });
Spark.Avatar({ text: "U", size: "large" });
Spark.Avatar({ text: "S", shape: "square" });</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">src</span><span class="prop-type">String</span><span class="prop-default">-</span><span class="prop-desc">图片路径</span></div>
      <div class="prop-item"><span class="prop-name">text</span><span class="prop-type">String</span><span class="prop-default">""</span><span class="prop-desc">文字 (取首字符)</span></div>
      <div class="prop-item"><span class="prop-name">shape</span><span class="prop-type">String</span><span class="prop-default">"circle"</span><span class="prop-desc">形状: circle / square</span></div>
      <div class="prop-item"><span class="prop-name">size</span><span class="prop-type">Number/String</span><span class="prop-default">32</span><span class="prop-desc">pixel 或 small/default/large</span></div>
      <div class="prop-item"><span class="prop-name">color</span><span class="prop-type">String</span><span class="prop-default">"#4B95FF"</span><span class="prop-desc">文字头像背景色</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body">
        <div style="display:flex;gap:12px;align-items:center">
          <div class="d-avatar" style="width:24px;height:24px;font-size:11px;">U</div>
          <div class="d-avatar" style="width:32px;height:32px;">U</div>
          <div class="d-avatar" style="width:40px;height:40px;font-size:16px;">U</div>
          <div class="d-avatar" style="width:48px;height:48px;font-size:18px;background:#f56a00">李</div>
        </div>
        <div style="display:flex;gap:12px;align-items:center;margin-top:4px">
          <div class="d-avatar" style="width:32px;height:32px;border-radius:4px;">S</div>
          <div class="d-avatar" style="width:40px;height:40px;border-radius:6px;background:#87d068;font-size:16px;">K</div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Collapse 折叠面板 =================== -->
<div class="section" id="comp-collapse">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Collapse 折叠面板 <span class="tag tag-extend">Extend</span></h1>
    <p>可折叠/展开的内容区域。支持手风琴模式。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Collapse({
  defaultActiveKey: ["1"],
  items: [
    { key: "1", label: "面板标题 1", children: [Spark.Text("内容1")] },
    { key: "2", label: "面板标题 2", children: [Spark.Text("内容2")] }
  ]
});
// 手风琴模式
Spark.Collapse({ accordion: true, items: [...] });</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">items</span><span class="prop-type">Array</span><span class="prop-default">[]</span><span class="prop-desc">[{ key, label, children }]</span></div>
      <div class="prop-item"><span class="prop-name">defaultActiveKey</span><span class="prop-type">Array</span><span class="prop-default">[]</span><span class="prop-desc">默认展开的 key 数组</span></div>
      <div class="prop-item"><span class="prop-name">accordion</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">手风琴模式</span></div>
      <div class="prop-item"><span class="prop-name">bordered</span><span class="prop-type">Boolean</span><span class="prop-default">true</span><span class="prop-desc">是否有边框</span></div>
      <div class="prop-item"><span class="prop-name">onChange</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">切换回调</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%;gap:6px">
        <div class="d-collapse-item" style="width:100%">
          <div class="d-collapse-head">面板标题 1 <span>▾</span></div>
          <div class="d-collapse-body">面板1的内容区域...</div>
        </div>
        <div class="d-collapse-item" style="width:100%">
          <div class="d-collapse-head">面板标题 2 <span>▸</span></div>
        </div>
        <div class="d-collapse-item" style="width:100%">
          <div class="d-collapse-head">面板标题 3 <span>▸</span></div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Steps 步骤条 =================== -->
<div class="section" id="comp-steps">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Steps 步骤条 <span class="tag tag-extend">Extend</span></h1>
    <p>引导用户按步骤完成任务的导航条。</p>
    <h2>基础用法</h2>
    <pre><code>var steps = Spark.Steps({
  current: 1,
  items: [
    { title: "注册账号" },
    { title: "填写信息", description: "补充个人资料" },
    { title: "完成验证" }
  ]
});
steps.setCurrent(2);</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">current</span><span class="prop-type">Number</span><span class="prop-default">0</span><span class="prop-desc">当前步骤 (0-based)</span></div>
      <div class="prop-item"><span class="prop-name">items</span><span class="prop-type">Array</span><span class="prop-default">[]</span><span class="prop-desc">[{ title, description }]</span></div>
      <div class="prop-item"><span class="prop-name">direction</span><span class="prop-type">String</span><span class="prop-default">"horizontal"</span><span class="prop-desc">horizontal / vertical</span></div>
      <div class="prop-item"><span class="prop-name">size</span><span class="prop-type">String</span><span class="prop-default">"default"</span><span class="prop-desc">default / small</span></div>
      <div class="prop-item"><span class="prop-name">onChange</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">步骤点击回调 (index)</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body center" style="width:100%">
        <div style="display:flex;align-items:center;gap:0;width:100%;justify-content:center">
          <div class="d-step"><span class="d-step-num done">✓</span><span>注册</span></div>
          <div class="d-step-line done"></div>
          <div class="d-step"><span class="d-step-num current">2</span><span>填写</span></div>
          <div class="d-step-line"></div>
          <div class="d-step"><span class="d-step-num">3</span><span>完成</span></div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Progress 进度条 =================== -->
<div class="section" id="comp-progress">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Progress 进度条 <span class="tag tag-extend">Extend</span></h1>
    <p>展示操作进度，支持线型和环形。</p>
    <h2>基础用法</h2>
    <pre><code>var bar = Spark.Progress({ percent: 70, status: "active" });
bar.setPercent(100);
bar.setStatus("success");

// 环形
Spark.Progress({ type: "circle", percent: 75, size: 120 });</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">percent</span><span class="prop-type">Number</span><span class="prop-default">0</span><span class="prop-desc">完成百分比 (0-100)</span></div>
      <div class="prop-item"><span class="prop-name">type</span><span class="prop-type">String</span><span class="prop-default">"line"</span><span class="prop-desc">类型: line / circle</span></div>
      <div class="prop-item"><span class="prop-name">status</span><span class="prop-type">String</span><span class="prop-default">"active"</span><span class="prop-desc">状态: active / success / exception</span></div>
      <div class="prop-item"><span class="prop-name">showInfo</span><span class="prop-type">Boolean</span><span class="prop-default">true</span><span class="prop-desc">是否显示百分比文字</span></div>
      <div class="prop-item"><span class="prop-name">strokeWidth</span><span class="prop-type">Number</span><span class="prop-default">8</span><span class="prop-desc">进度条粗细</span></div>
      <div class="prop-item"><span class="prop-name">strokeColor</span><span class="prop-type">String</span><span class="prop-default">"#4B95FF"</span><span class="prop-desc">进度条颜色</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%">
        <div style="width:100%">
          <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px"><span>进行中</span><span>70%</span></div>
          <div class="d-progress"><div class="d-progress-bar" style="width:70%"></div></div>
        </div>
        <div style="width:100%">
          <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px"><span style="color:#52c41a">已完成</span><span>100%</span></div>
          <div class="d-progress"><div class="d-progress-bar" style="width:100%;background:#52c41a"></div></div>
        </div>
        <div style="width:100%">
          <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px"><span style="color:#ff4d4f">异常</span><span>40%</span></div>
          <div class="d-progress"><div class="d-progress-bar" style="width:40%;background:#ff4d4f"></div></div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Empty 空状态 =================== -->
<div class="section" id="comp-empty">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Empty 空状态 <span class="tag tag-extend">Extend</span></h1>
    <p>空数据时的占位提示。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Empty();
Spark.Empty({ description: "暂无搜索结果" });
Spark.Empty({
  image: "https://example.com/empty.svg",
  description: "什么都没有找到",
  child: [Spark.Button("去创建")]
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">description</span><span class="prop-type">String/false</span><span class="prop-default">"暂无数据"</span><span class="prop-desc">描述文字；false 则不显示</span></div>
      <div class="prop-item"><span class="prop-name">image</span><span class="prop-type">String/Widget</span><span class="prop-default">默认图标</span><span class="prop-desc">自定义图片</span></div>
      <div class="prop-item"><span class="prop-name">child</span><span class="prop-type">Array</span><span class="prop-default">-</span><span class="prop-desc">额外操作 (如按钮)</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body center" style="width:100%">
        <div class="d-empty">
          <div class="d-empty-icon">📭</div>
          <div style="font-size:14px;margin-bottom:8px">暂无数据</div>
          <span class="d-btn d-btn-sm d-btn-outline">去创建</span>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Skeleton 骨架屏 =================== -->
<div class="section" id="comp-skeleton">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Skeleton 骨架屏 <span class="tag tag-extend">Extend</span></h1>
    <p>数据加载前的占位效果。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Skeleton();
Spark.Skeleton({ avatar: true });
Spark.Skeleton({ rows: 5 });
Spark.Skeleton({ active: false });</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">active</span><span class="prop-type">Boolean</span><span class="prop-default">true</span><span class="prop-desc">是否有渐变动画</span></div>
      <div class="prop-item"><span class="prop-name">avatar</span><span class="prop-type">Boolean/Object</span><span class="prop-default">false</span><span class="prop-desc">是否显示头像占位; { size, shape }</span></div>
      <div class="prop-item"><span class="prop-name">title</span><span class="prop-type">Boolean</span><span class="prop-default">true</span><span class="prop-desc">是否显示标题占位</span></div>
      <div class="prop-item"><span class="prop-name">paragraph</span><span class="prop-type">Boolean</span><span class="prop-default">true</span><span class="prop-desc">是否显示段落占位</span></div>
      <div class="prop-item"><span class="prop-name">rows</span><span class="prop-type">Number</span><span class="prop-default">3</span><span class="prop-desc">段落占位行数</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%">
        <div style="display:flex;gap:12px;width:100%">
          <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 50%,#f0f0f0 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;flex-shrink:0"></div>
          <div style="flex:1;display:flex;flex-direction:column;gap:8px">
            <div class="d-skeleton-line" style="width:50%;height:16px"></div>
            <div class="d-skeleton-line" style="width:100%"></div>
            <div class="d-skeleton-line" style="width:100%"></div>
            <div class="d-skeleton-line" style="width:75%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== List 列表 =================== -->
<div class="section" id="comp-list">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>List 列表 <span class="tag tag-base">Base</span></h1>
    <p>基础列表渲染组件，支持数据驱动的列表项生成。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.List({
  data: ["苹果", "橘子", "香蕉"],
  item: function (item, index) {
    return Spark.Box({
      style: "padding:12px; border-bottom:1px solid #f0f0f0;",
      child: [Spark.Text(item)]
    });
  }
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">data</span><span class="prop-type">Array</span><span class="prop-desc">数据源</span></div>
      <div class="prop-item"><span class="prop-name">item</span><span class="prop-type">Function</span><span class="prop-desc">渲染函数 (item, index) =&gt; Widget</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%;padding:0;gap:0">
        <div style="padding:12px 20px;border-bottom:1px solid var(--border);font-size:14px;display:flex;justify-content:space-between;width:100%"><span>🍎 苹果</span><span style="color:var(--text-sec);font-size:12px">#0</span></div>
        <div style="padding:12px 20px;border-bottom:1px solid var(--border);font-size:14px;display:flex;justify-content:space-between;width:100%"><span>🍊 橘子</span><span style="color:var(--text-sec);font-size:12px">#1</span></div>
        <div style="padding:12px 20px;font-size:14px;display:flex;justify-content:space-between;width:100%"><span>🍌 香蕉</span><span style="color:var(--text-sec);font-size:12px">#2</span></div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Breadcrumb 面包屑 =================== -->
<div class="section" id="comp-breadcrumb">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Breadcrumb 面包屑 <span class="tag tag-extend">Extend</span></h1>
    <p>显示当前页面在层级结构中的位置。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Breadcrumb({
  items: [
    { title: "首页" },
    { title: "列表页" },
    { title: "详情页" }
  ],
  onClick: function (item, index) {
    console.log("点击:", item.title);
  }
});
Spark.Breadcrumb({ separator: ">", items: [...] });</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">items</span><span class="prop-type">Array</span><span class="prop-default">[]</span><span class="prop-desc">[{ title, onClick? }]</span></div>
      <div class="prop-item"><span class="prop-name">separator</span><span class="prop-type">String</span><span class="prop-default">"/"</span><span class="prop-desc">分隔符</span></div>
      <div class="prop-item"><span class="prop-name">onClick</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">全局点击回调 (item, index)</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body">
        <div class="d-breadcrumb"><a href="javascript:;" style="color:var(--primary)">首页</a><em>/</em><a href="javascript:;" style="color:var(--primary)">列表页</a><em>/</em><span>详情页</span></div>
        <div class="d-breadcrumb" style="margin-top:4px"><a href="javascript:;" style="color:var(--primary)">Home</a><em>&gt;</em><a href="javascript:;" style="color:var(--primary)">Category</a><em>&gt;</em><span>Current</span></div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Tooltip 提示 =================== -->
<div class="section" id="comp-tooltip">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Tooltip 文字提示 <span class="tag tag-extend">Extend</span></h1>
    <p>鼠标悬停时显示的提示气泡。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Tooltip({
  title: "提示文字内容",
  placement: "top",
  child: Spark.Button("悬停查看")
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">title</span><span class="prop-type">String</span><span class="prop-default">""</span><span class="prop-desc">提示内容</span></div>
      <div class="prop-item"><span class="prop-name">placement</span><span class="prop-type">String</span><span class="prop-default">"top"</span><span class="prop-desc">方向: top / bottom / left / right</span></div>
      <div class="prop-item"><span class="prop-name">color</span><span class="prop-type">String</span><span class="prop-default">"rgba(0,0,0,0.75)"</span><span class="prop-desc">气泡背景色</span></div>
      <div class="prop-item"><span class="prop-name">child</span><span class="prop-type">Widget</span><span class="prop-default">-</span><span class="prop-desc">被包裹的组件</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body center">
        <div class="d-tooltip-wrap" style="margin-top:28px">
          <div class="d-tooltip">提示文字内容</div>
          <span class="d-btn d-btn-sm">悬停查看</span>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Alert 警告 =================== -->
<div class="section" id="comp-alert">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Alert 警告提示 <span class="tag tag-extend">Extend</span></h1>
    <p>页面中展示重要信息的提示框。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Alert({ type: "success", message: "操作成功！" });
Spark.Alert({ type: "info", message: "这是一条提示信息。" });
Spark.Alert({ type: "warning", message: "注意注意！" });
Spark.Alert({ type: "error", message: "出错了！" });
Spark.Alert({
  type: "info",
  message: "信息标题",
  description: "详细的补充说明文字。",
  closable: true
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">type</span><span class="prop-type">String</span><span class="prop-default">"info"</span><span class="prop-desc">类型: success / info / warning / error</span></div>
      <div class="prop-item"><span class="prop-name">message</span><span class="prop-type">String</span><span class="prop-default">""</span><span class="prop-desc">提示标题</span></div>
      <div class="prop-item"><span class="prop-name">description</span><span class="prop-type">String</span><span class="prop-default">""</span><span class="prop-desc">辅助描述</span></div>
      <div class="prop-item"><span class="prop-name">closable</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">是否可关闭</span></div>
      <div class="prop-item"><span class="prop-name">banner</span><span class="prop-type">Boolean</span><span class="prop-default">false</span><span class="prop-desc">通栏模式（无边框圆角）</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%">
        <div class="d-alert d-alert-success">✅ 操作成功！</div>
        <div class="d-alert d-alert-info">ℹ️ 这是一条提示信息。</div>
        <div class="d-alert d-alert-warning">⚠️ 注意注意！</div>
        <div class="d-alert d-alert-error">❌ 出错了！</div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Modal 对话框 =================== -->
<div class="section" id="comp-modal">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Modal 对话框 <span class="tag tag-extend">Extend</span></h1>
    <p>模态弹窗，用于需要用户处理事务且不希望跳转页面时。</p>
    <h2>基础用法</h2>
    <pre><code>var modal = Spark.Modal({
  title: "提示",
  content: "确定要删除吗？",
  okText: "确定",
  cancelText: "取消",
  okEvent: function () { console.log("确认"); }
});
modal.show();
modal.hide();</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">title</span><span class="prop-type">String</span><span class="prop-default">""</span><span class="prop-desc">标题</span></div>
      <div class="prop-item"><span class="prop-name">content</span><span class="prop-type">String/Widget</span><span class="prop-default">""</span><span class="prop-desc">内容</span></div>
      <div class="prop-item"><span class="prop-name">okText</span><span class="prop-type">String</span><span class="prop-default">"确定"</span><span class="prop-desc">确认按钮文字</span></div>
      <div class="prop-item"><span class="prop-name">cancelText</span><span class="prop-type">String</span><span class="prop-default">"取消"</span><span class="prop-desc">取消按钮文字</span></div>
      <div class="prop-item"><span class="prop-name">okEvent</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">确认回调</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body center" style="width:100%">
        <div style="width:100%;border:1px solid var(--border);border-radius:var(--radius);box-shadow:0 4px 16px rgba(0,0,0,.1);overflow:hidden">
          <div style="padding:12px 16px;border-bottom:1px solid var(--border);font-weight:600;font-size:15px;display:flex;justify-content:space-between"><span>提示</span><span style="cursor:pointer;color:var(--text-sec)">×</span></div>
          <div style="padding:20px 16px;font-size:14px;">确定要删除吗？</div>
          <div style="padding:10px 16px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px">
            <span class="d-btn d-btn-sm d-btn-outline">取消</span>
            <span class="d-btn d-btn-sm">确定</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Drawer 抽屉 =================== -->
<div class="section" id="comp-drawer">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Drawer 抽屉 <span class="tag tag-extend">Extend</span></h1>
    <p>侧滑面板，可以从四个方向抽出。</p>
    <h2>基础用法</h2>
    <pre><code>var drawer = Spark.Drawer({
  title: "抽屉标题",
  placement: "right",
  width: 400,
  child: [
    Spark.Text("这是抽屉内容"),
    Spark.Button("关闭", {
      onClick: function () { drawer.close(); }
    })
  ]
});
drawer.open();
drawer.close();</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">title</span><span class="prop-type">String</span><span class="prop-default">""</span><span class="prop-desc">抽屉标题</span></div>
      <div class="prop-item"><span class="prop-name">placement</span><span class="prop-type">String</span><span class="prop-default">"right"</span><span class="prop-desc">方向: right / left / top / bottom</span></div>
      <div class="prop-item"><span class="prop-name">width</span><span class="prop-type">Number</span><span class="prop-default">378</span><span class="prop-desc">宽度（水平方向时）</span></div>
      <div class="prop-item"><span class="prop-name">height</span><span class="prop-type">Number</span><span class="prop-default">378</span><span class="prop-desc">高度（垂直方向时）</span></div>
      <div class="prop-item"><span class="prop-name">closable</span><span class="prop-type">Boolean</span><span class="prop-default">true</span><span class="prop-desc">是否显示关闭按钮</span></div>
      <div class="prop-item"><span class="prop-name">maskClosable</span><span class="prop-type">Boolean</span><span class="prop-default">true</span><span class="prop-desc">点击遮罩是否关闭</span></div>
      <div class="prop-item"><span class="prop-name">onClose</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">关闭回调</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%">
        <div class="d-drawer">
          <div class="d-drawer-head"><span>抽屉标题</span><span style="cursor:pointer;color:var(--text-sec)">×</span></div>
          <div class="d-drawer-body">这是抽屉内容区域...<br><span class="d-btn d-btn-sm" style="margin-top:8px">关闭</span></div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Message 消息 =================== -->
<div class="section" id="comp-message">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Message 全局提示 <span class="tag tag-extend">Extend</span></h1>
    <p>轻量级全局提示，从页面顶部弹出，自动消失。类似 toast。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Message.success("操作成功！");
Spark.Message.error("操作失败！");
Spark.Message.warning("注意事项...");
Spark.Message.info("提示信息");
Spark.Message.loading("加载中...");

// 自定义持续时间
Spark.Message.success("保存成功", 5);

// 手动关闭
var msg = Spark.Message.loading("处理中...", 0);
msg.close();</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">Message.success(content, duration?, onClose?)</span><span class="prop-desc">成功提示</span></div>
      <div class="prop-item"><span class="prop-name">Message.error(content, duration?, onClose?)</span><span class="prop-desc">失败提示</span></div>
      <div class="prop-item"><span class="prop-name">Message.warning(content, duration?, onClose?)</span><span class="prop-desc">警告提示</span></div>
      <div class="prop-item"><span class="prop-name">Message.info(content, duration?, onClose?)</span><span class="prop-desc">信息提示</span></div>
      <div class="prop-item"><span class="prop-name">Message.loading(content, duration?, onClose?)</span><span class="prop-desc">加载提示</span></div>
    </div>
    <p><code>duration</code> 默认为 3 秒，设为 0 则不自动关闭。返回值含 <code>close()</code> 方法。</p>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body center" style="width:100%">
        <div class="d-msg">✅ 操作成功！</div>
        <div class="d-msg">❌ 操作失败！</div>
        <div class="d-msg">⚠️ 注意事项...</div>
        <div class="d-msg">ℹ️ 提示信息</div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Notification 通知 =================== -->
<div class="section" id="comp-notification">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Notification 通知提醒 <span class="tag tag-extend">Extend</span></h1>
    <p>从角落弹出的通知框，适用于较为复杂的内容展示。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Notification.success({
  message: "上传成功",
  description: "文件 photo.jpg 已上传至服务器。"
});
Spark.Notification.error({
  message: "请求失败",
  description: "网络连接异常，请检查后重试。",
  duration: 0
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">message</span><span class="prop-type">String</span><span class="prop-default">""</span><span class="prop-desc">通知标题</span></div>
      <div class="prop-item"><span class="prop-name">description</span><span class="prop-type">String</span><span class="prop-default">""</span><span class="prop-desc">详细内容</span></div>
      <div class="prop-item"><span class="prop-name">type</span><span class="prop-type">String</span><span class="prop-default">"info"</span><span class="prop-desc">类型: success / error / warning / info</span></div>
      <div class="prop-item"><span class="prop-name">duration</span><span class="prop-type">Number</span><span class="prop-default">4.5</span><span class="prop-desc">持续时间 (秒)，0 不自动关闭</span></div>
      <div class="prop-item"><span class="prop-name">placement</span><span class="prop-type">String</span><span class="prop-default">"topRight"</span><span class="prop-desc">位置: topRight / topLeft / bottomRight / bottomLeft</span></div>
      <div class="prop-item"><span class="prop-name">closable</span><span class="prop-type">Boolean</span><span class="prop-default">true</span><span class="prop-desc">是否显示关闭按钮</span></div>
      <div class="prop-item"><span class="prop-name">onClose</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">关闭回调</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body" style="width:100%">
        <div style="border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);padding:14px 16px;width:100%">
          <div style="display:flex;justify-content:space-between;margin-bottom:6px"><strong style="font-size:14px">✅ 上传成功</strong><span style="cursor:pointer;color:var(--text-sec);font-size:12px">×</span></div>
          <p style="font-size:13px;color:var(--text-sec);margin:0">文件 photo.jpg 已上传至服务器。</p>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Dropdown 下拉菜单 =================== -->
<div class="section" id="comp-dropdown">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Dropdown 下拉菜单 <span class="tag tag-extend">Extend</span></h1>
    <p>向下弹出的菜单列表。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Dropdown({
  child: Spark.Button("操作菜单 ▾"),
  trigger: "hover",
  items: [
    { key: "edit", label: "编辑" },
    { key: "copy", label: "复制" },
    { type: "divider" },
    { key: "delete", label: "删除", danger: true }
  ],
  onSelect: function (key, item) {
    console.log("选择:", key);
  }
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">child</span><span class="prop-type">Widget</span><span class="prop-default">-</span><span class="prop-desc">触发元素</span></div>
      <div class="prop-item"><span class="prop-name">items</span><span class="prop-type">Array</span><span class="prop-default">[]</span><span class="prop-desc">[{ key, label, disabled?, danger?, type? }]</span></div>
      <div class="prop-item"><span class="prop-name">trigger</span><span class="prop-type">String</span><span class="prop-default">"hover"</span><span class="prop-desc">触发方式: hover / click</span></div>
      <div class="prop-item"><span class="prop-name">placement</span><span class="prop-type">String</span><span class="prop-default">"bottomLeft"</span><span class="prop-desc">弹出位置</span></div>
      <div class="prop-item"><span class="prop-name">onSelect</span><span class="prop-type">Function</span><span class="prop-default">-</span><span class="prop-desc">选择回调 (key, item)</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body">
        <span class="d-btn d-btn-sm" style="margin-bottom:8px">操作菜单 ▾</span>
        <div class="d-dropdown-menu">
          <div class="d-dropdown-item">编辑</div>
          <div class="d-dropdown-item">复制</div>
          <div class="d-dropdown-divider"></div>
          <div class="d-dropdown-item danger">删除</div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== BackTop 回到顶部 =================== -->
<div class="section" id="comp-backtop">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>BackTop 回到顶部 <span class="tag tag-extend">Extend</span></h1>
    <p>页面滚动超过一定高度后出现回到顶部按钮。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.BackTop();
Spark.BackTop({
  visibilityHeight: 200,
  right: 40, bottom: 60, duration: 300
});
Spark.BackTop({
  child: [Spark.Box({
    style: "width:40px;height:40px;background:#4B95FF;color:#fff;border-radius:4px;" +
      "display:flex;align-items:center;justify-content:center;",
    child: [Spark.Text("TOP")]
  })]
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">visibilityHeight</span><span class="prop-type">Number</span><span class="prop-default">400</span><span class="prop-desc">滚动超过该高度后显示 (px)</span></div>
      <div class="prop-item"><span class="prop-name">duration</span><span class="prop-type">Number</span><span class="prop-default">450</span><span class="prop-desc">滚动回顶部的动画时长 (ms)</span></div>
      <div class="prop-item"><span class="prop-name">right</span><span class="prop-type">Number</span><span class="prop-default">40</span><span class="prop-desc">距右端距离 (px)</span></div>
      <div class="prop-item"><span class="prop-name">bottom</span><span class="prop-type">Number</span><span class="prop-default">40</span><span class="prop-desc">距底部距离 (px)</span></div>
      <div class="prop-item"><span class="prop-name">child</span><span class="prop-type">Array</span><span class="prop-default">默认箭头</span><span class="prop-desc">自定义内容</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body center">
        <div style="width:44px;height:44px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(75,149,255,.4);font-size:18px;cursor:pointer">↑</div>
        <div style="width:40px;height:40px;border-radius:4px;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:bold;margin-top:4px">TOP</div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- =================== Drag 拖拽 =================== -->
<div class="section" id="comp-drag">
<div class="comp-layout">
  <div class="comp-doc">
    <h1>Drag 拖拽 <span class="tag tag-base">Base</span></h1>
    <p>可拖拽区域组件，支持 press / move / up 事件。</p>
    <h2>基础用法</h2>
    <pre><code>Spark.Drag({
  style: "width:200px; height:200px; background:#f0f0f0; border-radius:8px;",
  press: function () { console.log("按下"); },
  move: function (e) { console.log("移动", e); },
  up: function () { console.log("松开"); }
});</code></pre>
    <h2>API</h2>
    <div class="prop-list">
      <div class="prop-item"><span class="prop-name">press</span><span class="prop-type">Function</span><span class="prop-desc">按下回调</span></div>
      <div class="prop-item"><span class="prop-name">move</span><span class="prop-type">Function</span><span class="prop-desc">移动回调 (event)</span></div>
      <div class="prop-item"><span class="prop-name">up</span><span class="prop-type">Function</span><span class="prop-desc">松开回调</span></div>
    </div>
  </div>
  <div class="comp-demo">
    <div class="demo-card">
      <div class="demo-card-title">效果预览</div>
      <div class="demo-card-body center">
        <div style="width:140px;height:100px;background:#f0f0f0;border:2px dashed var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:grab;color:var(--text-sec);font-size:13px;">↕ 拖拽区域</div>
      </div>
    </div>
  </div>
</div>
</div>

</main>

<script>
// Section switching
function showSection(id) {
  var sections = document.querySelectorAll('.section');
  for (var i = 0; i < sections.length; i++) {
    sections[i].classList.remove('active');
  }
  document.getElementById(id).classList.add('active');

  var items = document.querySelectorAll('.sidebar-item');
  for (var i = 0; i < items.length; i++) {
    items[i].classList.remove('active');
    if (items[i].getAttribute('data-section') === id) {
      items[i].classList.add('active');
    }
  }

  window.scrollTo(0, 0);
  history.pushState(null, '', '#' + id);
}

// Handle URL hash on load
window.addEventListener('DOMContentLoaded', function () {
  var hash = location.hash.replace('#', '');
  if (hash && document.getElementById(hash)) {
    showSection(hash);
  }
});

// Search filtering
var searchInput = document.querySelector('.header-search input');
if (searchInput) {
  searchInput.addEventListener('input', function () {
    var query = this.value.toLowerCase();
    var items = document.querySelectorAll('.sidebar-item');
    for (var i = 0; i < items.length; i++) {
      var text = items[i].textContent.toLowerCase();
      items[i].style.display = (!query || text.indexOf(query) > -1) ? '' : 'none';
    }
  });
}
</script>
</body>
</html>